---
import GradientBlurBg from './GradientBlurBg.astro';
---

<section id="hero" class="bg-main-bg relative min-h-screen">
  <GradientBlurBg>
    <div class="flex flex-col items-center justify-center min-h-screen px-4 text-center">
      
<h1 id="hero-title" class="text-5xl md:text-9xl font-black uppercase leading-none text-title overflow-hidden flex flex-col md:block">
  <span class="hero-title-left inline-block">Développeur de site</span>
  <br class="hidden md:block" /> <span class="hero-title-right text-gradient inline-block">sur mesure</span>
</h1>
      
      <p id="hero-desc" class="mt-8 text-lg md:text-xl text-body-text max-w-xl">
        Spécialiste dans la création de site web. La <strong class="font-bold">précision</strong> du code. L'<strong class="font-bold">élégance</strong> du design. L'<strong class="font-bold">obsession</strong> du résultat.
      </p>

      <div id="hero-cta" class="flex flex-col md:flex-row mt-12 gap-4">
        <a href="#form" class="bg-brand-gradient text-white px-4 md:px-10 py-4 rounded-full font-bold shadow-lg hover:scale-105 transition-transform duration-300 inline-block">
          Demander un devis
        </a>
        <a href="#projets" class="border border-[#c461ff] bg-transparent hover:bg-[#c461ff]/30 text-title px-10 py-4 rounded-full font-bold shadow-lg hover:scale-105 transition-transform duration-300 inline-block">
          Mes réalisations
        </a>
      </div>
    </div>
  </GradientBlurBg>
</section>

<script>
import { gsap } from "gsap/dist/gsap";

const tl = gsap.timeline();

// 1. Animation synchronisée du titre
tl.from(".hero-title-left", { 
    x: -1000,           // Vient de la gauche (-X)
    opacity: 0, 
    duration: 2,     // Un peu plus long pour plus d'élégance
    ease: "power4.out" 
  })
  .from(".hero-title-right", { 
    x: 800,            // Vient de la droite (+X)
    opacity: 0, 
    duration: 2, 
    ease: "power4.out" 
  }, "<")              // "<" Force le démarrage en MÊME TEMPS que l'animation précédente

// 2. Suite de ton animation originale (inchangée)
  .from("#hero-desc", { 
    y: 20, 
    opacity: 0, 
    duration: 0.8, 
    ease: "power3.out" // Ajout d'un ease pour la fluidité
  }, "-=0.8")          // Légère synchronisation avec la fin du titre
  
  .from("#hero-cta", { 
    scale: 0.8, 
    opacity: 0, 
    duration: 0.5, 
    ease: "back.out(1.7)" // Un petit effet de rebond sympa pour le bouton
  }, "-=0.5");
</script>