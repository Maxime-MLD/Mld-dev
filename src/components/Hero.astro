---
import GradientBlurBg from './gradient-blur-bg';
---

<section class="bg-main-bg relative min-h-screen">
  <GradientBlurBg client:load>
    <div class="flex flex-col items-center justify-center min-h-screen px-4 text-center">
      
      <h1 id="hero-title" class="text-6xl md:text-9xl font-black uppercase leading-none text-title">
        Développeur de site<br /> 
        <span class="text-gradient">sur mesure</span>
      </h1>
      
      <p id="hero-desc" class="mt-8 text-lg md:text-xl text-body-text max-w-xl">
        Spécialiste dans la création de site web. La <strong class="font-bold">précision</strong> du code. L'<strong class="font-bold">élégance</strong> du design. L'<strong class="font-bold">obsession</strong> du résultat.
      </p>

      <div id="hero-cta" class="mt-12 flex gap-4">
        <a href="#tarifs" class="bg-brand-gradient text-white px-10 py-4 rounded-full font-bold shadow-lg hover:scale-105 transition-transform duration-300 inline-block">
          Un projet ?
        </a>
        <a href="#projets" class="border border-[#c461ff] bg-transparent hover:bg-[#c461ff]/20 text-title px-10 py-4 rounded-full font-bold shadow-lg hover:scale-105 transition-transform duration-300 inline-block">
          Mes réalisations
        </a>
      </div>
    </div>
  </GradientBlurBg>
</section>

<script>
  import { gsap } from "gsap";

  const tl = gsap.timeline();
  tl.from("#hero-title", { y: 100, opacity: 0, duration: 1.2, ease: "power4.out" })
    .from("#hero-desc", { y: 20, opacity: 0, duration: 0.8 }, "-=0.6")
    .from("#hero-cta", { scale: 0.8, opacity: 0, duration: 0.5 }, "-=0.4");
</script>