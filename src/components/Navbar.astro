---

---

<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[90%] max-w-4xl">
  <div class="hidden bg-white/30 backdrop-blur-lg border border-white/20 px-6 py-3 rounded-full lg:flex justify-between items-center shadow-2xl">
    <a href="/" class="font-display font-bold text-xl tracking-tighter">
      MLD<span class="text-brand-gradient text-xl">.</span>
    </a>

    <ul class="hidden lg:flex gap-8 text-sm font-medium uppercase tracking-widest">
      <li>
        <a href="#projets" class="group relative block overflow-hidden leading-tight">
          <div class="transition-transform duration-500 ease-in-out group-hover:-translate-y-full">
            <span class="block text-title">Projets</span>
          </div>
          <div class="absolute inset-0 transition-transform duration-500 ease-in-out translate-y-full group-hover:translate-y-0 text-[#6352ff]">
            <span class="block">Projets</span>
          </div>
        </a>
      </li>
      <li>
        <a href="#tarifs" class="group relative block overflow-hidden leading-tight">
          <div class="transition-transform duration-500 ease-in-out group-hover:-translate-y-full">
            <span class="block text-title">Tarifs</span>
          </div>
          <div class="absolute inset-0 transition-transform duration-500 ease-in-out translate-y-full group-hover:translate-y-0 text-[#6352ff]">
            <span class="block">Tarifs</span>
          </div>
        </a>
      </li>
      <li>
        <a href="#contact" class="group relative block overflow-hidden leading-tight">
          <div class="transition-transform duration-500 ease-in-out group-hover:-translate-y-full">
            <span class="block text-title">Contact</span>
          </div>
          <div class="absolute inset-0 transition-transform duration-500 ease-in-out translate-y-full group-hover:translate-y-0 text-[#6352ff]">
            <span class="block">Contact</span>
          </div>
        </a>
      </li>
    </ul>

    <a href="mailto:contact@mld.com" class="hidden md:block text-[#6352ff] text-sm border border-[#6352ff] px-5 py-2 rounded-full hover:scale-105 hover:bg-[#6352ff]/80 hover:text-white transition-all duration-300">
      CONTACTE-MOI
    </a>
  </div>

  <!-- Nav-Bar Mobile -->
  <div class="lg:hidden fixed top-0 left-0 w-full p-4">
    <div class="nav-pill-mobile max-w-7xl mx-auto flex justify-between items-center bg-white/30 backdrop-blur-lg border border-white/20 p-4 rounded-full shadow-sm relative z-110">
      <a href="/" class="text-2xl font-black text-title">MLD.</a>
      <button id="menu-btn" class="p-2 outline-none">
        <div id="burger-icon" class="space-y-1.5">
          <span class="block w-6 h-0.5 bg-title transition-transform duration-300"></span>
          <span class="block w-6 h-0.5 bg-title transition-opacity duration-300"></span>
          <span class="block w-6 h-0.5 bg-title transition-transform duration-300"></span>
        </div>
      </button>
    </div>

    <div id="mobile-menu" class="fixed inset-0 z-100 opacity-0 pointer-events-none transition-opacity duration-300 ease-in-out">
      <div id="menu-overlay" class="absolute inset-0 bg-white/40 backdrop-blur-2xl"></div>
      
      <div class="absolute top-0 left-0 w-full bg-white/60 backdrop-blur-3xl border-b border-white/30 pt-32 pb-12 px-8 shadow-2xl">
        <nav class="flex flex-col gap-6">
          <a href="/#hero" class="mobile-link text-xl font-bold uppercase tracking-widest text-title">Accueil</a>
          <a href="/#projets" class="mobile-link text-xl font-bold uppercase tracking-widest text-title">Projets</a>
          <a href="/#tarifs" class="mobile-link text-xl font-bold uppercase tracking-widest text-title">Tarifs</a>
          <a href="/#form" class="mobile-link text-xl font-bold uppercase tracking-widest text-[#6352ff]">Contact</a>
        </nav>
      </div>
    </div>
  </div>
</nav>

<script>
  import { gsap } from "gsap";

  // Animation d'entrée
  gsap.from(".hidden.lg\\:flex, .nav-pill-mobile", {
    y: -50,
    opacity: 0,
    duration: 1,
    delay: 0.5,
    ease: "power3.out"
  });

  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOverlay = document.getElementById('menu-overlay');
  const links = document.querySelectorAll('.mobile-link');
  const spans = menuBtn?.querySelectorAll('span');

  function toggleMenu() {
    if (mobileMenu && menuBtn && spans) {
      const isOpening = mobileMenu.classList.contains('pointer-events-none');
      
      if (isOpening) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        document.body.style.overflow = 'hidden';
        // Animation burger vers croix
        spans[0].style.transform = "translateY(8px) rotate(45deg)";
        spans[1].style.opacity = "0";
        spans[2].style.transform = "translateY(-8px) rotate(-45deg)";
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        document.body.style.overflow = '';
        // Retour burger
        spans[0].style.transform = "translateY(0) rotate(0)";
        spans[1].style.opacity = "1";
        spans[2].style.transform = "translateY(0) rotate(0)";
      }
    }
  }

  if (menuBtn && mobileMenu && menuOverlay) {
    menuBtn.addEventListener('click', toggleMenu);
    menuOverlay.addEventListener('click', toggleMenu);
    links.forEach(link => link.addEventListener('click', toggleMenu));
  }
</script>