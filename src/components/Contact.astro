---

---

<section id="contact" class="py-24 px-6 bg-section-bg text-white">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20">
    
    <div>
      <span class="text-[#6352ff] text-base mb-4 block font-mono uppercase tracking-widest">// Contact</span>
      <h2 class="text-4xl font-black uppercase text-white leading-tight">
        Prêt à donner <br /> vie à votre <br /> <span class="text-[#6352ff]">vision ?</span>
      </h2>
      <p class="text-white/50 text-sm mb-12">Vous avez un projet ambitieux ? Un produit à lancer ?<br>Une refonte qui traîne depuis trop longtemps ?<br>Parlons-en — je réponds dans les 24h.</p>
      
      <div class="space-y-8">
        <div class="flex items-center gap-4 mb-10 pb-6 border-b border-white/10">
    <div class="w-10 h-10 shrink-0 text-[#6352ff]">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
      </svg>
    </div>
    <p class="text-xs md:text-sm font-bold uppercase tracking-widest text-white/80 leading-relaxed">
      Nous pouvons créer votre site <br><span class="text-[#6352ff]">partout dans le monde</span>.
    </p>
  </div>
        <!-- <div>
          <p class="text-white/50 uppercase text-[10px] font-black tracking-widest mb-2">Email</p>
          <a href="mailto:votre@email.com" class="text-2xl font-bold hover:text-[#6352ff] transition-colors">votre@email.com</a>
        </div> -->
        <div>
          <p class="text-white/50 uppercase text-[10px] font-black tracking-widest mb-2">Social</p>
          <div class="flex gap-6">
            <a href="#" class="font-bold hover:text-[#6352ff] transition-colors italic">LinkedIn</a>
            <a href="#" class="font-bold hover:text-[#6352ff] transition-colors italic">Instagram</a>
            <a href="#" class="font-bold hover:text-[#6352ff] transition-colors italic">X (Twitter)</a>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white/5 p-8 md:p-12 rounded-[32px] border border-white/10 backdrop-blur-sm">
      <form action="#" method="POST" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-[10px] uppercase font-black tracking-widest text-white/80 ml-2">Nom</label>
            <input type="text" placeholder="Jean Dupont" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 outline-none focus:border-[#6352ff] transition-colors text-white placeholder:text-white/40" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] uppercase font-black tracking-widest text-white/80 ml-2">Email</label>
            <input type="email" placeholder="jean@mail.com" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 outline-none focus:border-[#6352ff] transition-colors text-white placeholder:text-white/40" />
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[10px] uppercase font-black tracking-widest text-white/80 ml-2">Votre projet</label>
          <select class="w-full bg-white/5 border border-white/40 rounded-2xl px-6 py-4 outline-none focus:border-[#6352ff] transition-colors text-white/40 appearance-none">
            <option class="text-title">Site Vitrine</option>
            <option class="text-title">Boutique E-commerce</option>
            <option class="text-title">Application Web / Sur Mesure</option>
          </select>
        </div>

        <div class="space-y-2">
          <label class="text-[10px] uppercase font-black tracking-widest text-white/80 ml-2">Message</label>
          <textarea rows="4" placeholder="Parlez-moi de vos objectifs..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 outline-none focus:border-[#6352ff] transition-colors text-white placeholder:text-white/40 resize-none"></textarea>
        </div>

        <button type="submit" class="w-full bg-[#6352ff] hover:bg-white hover:text-title text-white font-black uppercase tracking-widest py-6 rounded-2xl transition-all duration-500 shadow-lg shadow-[#6352ff]/20">
          Envoyer la demande
        </button>
      </form>
    </div>
  </div>
</section>